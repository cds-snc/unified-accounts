{
	"name": "platform-unified-accounts",
	"image": "mcr.microsoft.com/devcontainers/base:bullseye@sha256:931914d4b3b738664c1019daf89ff963ff3840b6284eaaa3fd88eb0afd83d89f",
	"containerEnv": {
		"SHELL": "/bin/zsh"
	},
	"features": {
		"ghcr.io/devcontainers/features/aws-cli:1": {
			"version": "latest"
		},
		"ghcr.io/devcontainers/features/go:1": {
			"version": "1.26.3"
		},
		"ghcr.io/devcontainers/features/terraform:1": {
			"version": "1.14.3",
			"terragrunt": "0.98.0"
		}
	},

	"customizations": {
		"vscode": {
			"extensions": [
				"hashicorp.terraform",
				"github.copilot",
				"github.vscode-github-actions",
				"hashicorp.hcl",
				"redhat.vscode-yaml"
			]
		},
		"codespaces": {
			"extensions": [
				"hashicorp.terraform",
				"github.copilot",
				"github.vscode-github-actions",
				"hashicorp.hcl",
				"redhat.vscode-yaml"
			]
		}
	},

	"remoteUser": "vscode"
}
