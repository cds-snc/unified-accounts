  {
    "rules": [
        {
            "rulePriority": 10,
            "description": "Keep last 20 git SHA tagged images",
            "selection": {
                "tagStatus": "tagged",
                "tagPrefixList": [
                    "sha-"
                ],
                "countType": "imageCountMoreThan",
                "countNumber": 20
            },
            "action": {
                "type": "expire"
            }
        },
        {
            "rulePriority": 20,
            "description": "Keep last 20 PR SHA tagged images",
            "selection": {
                "tagStatus": "tagged",
                "tagPrefixList": [
                    "pr-"
                ],
                "countType": "imageCountMoreThan",
                "countNumber": 20
            },
            "action": {
                "type": "expire"
            }
        },
        {
            "rulePriority": 30,
            "description": "Expire untagged images older than 1 day",
            "selection": {
                "tagStatus": "untagged",
                "countType": "sinceImagePushed",
                "countUnit": "days",
                "countNumber": 1
            },
            "action": {
                "type": "expire"
            }
        }
    ]
  }